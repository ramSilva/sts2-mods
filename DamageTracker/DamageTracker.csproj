<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../common/common.props" />

  <PropertyGroup>
    <AssemblyName>DamageTracker</AssemblyName>
    <RootNamespace>DamageTracker</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../common/*.cs">
      <Link>common/%(Filename)%(Extension)</Link>
    </Compile>
  </ItemGroup>

  <Target Name="StageMod" AfterTargets="Build" Condition="'$(SkipStage)' != 'true'">
    <PropertyGroup>
      <StageDir>$(MSBuildProjectDirectory)/build/mods/DamageTracker</StageDir>
    </PropertyGroup>
    <MakeDir Directories="$(StageDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(StageDir)" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)/DamageTracker.json" DestinationFolder="$(StageDir)" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)/godot/mod_manifest.json" DestinationFolder="$(StageDir)" />
    <Message Importance="high" Text="Staged DamageTracker mod to $(StageDir)" />
  </Target>

</Project>
